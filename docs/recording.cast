[0.000, "o", "                                                                                \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[48;2;232;240;232m \u001b[38;2;0;0;255mimport\u001b[39m { GameRuntime, \u001b[38;2;0;0;255mtype\u001b[39m IntervalScheduler } \u001b[38;2;0;0;255mfrom\u001b[39m \u001b[38;2;163;21;21m\"./runtime.js\"\u001b[39m;                                                                                                       \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[48;2;232;240;232m                                                                                                                                                                           \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[48;2;232;240;232m \u001b[38;2;0;0;255mconst\u001b[39m datacenterId = (value: \u001b[38;2;38;127;153mstring\u001b[39m): \u001b[38;2;121;94;38m\u001b[38;2;0;16;128mDatacenterId\u001b[39m =>\u001b[39m value \u001b[38;2;0;0;255mas\u001b[39m DatacenterId;                                                                                              \u001b[49m\u001b[0m\u001b]8;;\u0007\r\r\n\u001b[48;2;232;240;232m \u001b[38;2;0;0;255mconst\u001b[39m rackPlacementId = (value: \u001b[38;2;38;127;153mstring\u001b[39m): \u001b[38;2;121"]
